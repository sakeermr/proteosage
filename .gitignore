# ProteoSage — .gitignore

# ── Secrets / Environment ─────────────────────────────────────
.env
.env.local
.env.*.local
secrets.toml
.streamlit/secrets.toml

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# ── Virtual Environments ──────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Testing / Coverage ────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Reports / Outputs ─────────────────────────────────────────
*.pdf
reports/
output/

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
